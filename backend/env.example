# Copy to shh.env (local) or set as Vercel Environment Variables
SECRET_KEY=your-secret-key-here

# Local PostgreSQL (optional)
DATABASE_URL=postgresql://postgres:password@localhost/climbing_app

# Supabase (for Vercel) - REQUIRED for deployment
# Supabase Dashboard → Project Settings → Database → Connection string → URI
# Choose "Transaction" mode (port 6543) for serverless
SUPABASE_DB_URL=postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
